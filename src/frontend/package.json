    "pako": "2.1.0",
    "postcss": "8.5.14",
    "prettier": "3.5.3",
    "qs": ">=6.15.2",
    "react": "19.1.0",
    "react-arborist": "3.4.3",
    "react-dom": "19.1.0",
    "react-json-view-lite": "2.4.1",
    "react-rnd": "10.5.2",
    "tailwindcss": "^4.3.0",
    "three": "0.176.0",
    "tsx": "^4.21.0",
    "typescript": "5.8.2",
    "urdf-loader": "0.12.4",
    "vite": "^6.4.1",
    "zustand": "5.0.3"
