    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "@types/three": "0.176.0",
    "@vitejs/plugin-react": "4.3.4",
    "@xyflow/react": "12.4.4",
    "archiver": "6.0.2",
    "camera-controls": "2.10.1",
    "comlink": "4.4.2",
    "cross-env": "^7.0.3",
    "depcheck": "^1.4.7",
    "dexie": "4.0.11",
    "esbuild": "0.25.1",
